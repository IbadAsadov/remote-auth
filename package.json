{
  "name": "remote-auth",
  "version": "1.0.0",
  "private": true,
  "description": "Authentication microfrontend - exposes LoginForm, RegisterForm, AuthRoutes",
  "scripts": {
    "dev": "bunx  rspack serve --config rspack.config.ts --env development",
    "build": "bunx  rspack build --config rspack.config.ts --env production",
    "build:analyze": "RSDOCTOR=true bunx rspack build --config rspack.config.ts --env production",
    "preview": "bunx serve dist --port 3001",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome lint ./src",
    "lint:fix": "biome lint --write ./src",
    "format": "biome format --write ./src",
    "format:check": "biome format ./src",
    "check": "biome check ./src",
    "check:fix": "biome check --write ./src"
  },
  "dependencies": {
    "@chakra-ui/react": "3.19.1",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.0",
    "@hookform/resolvers": "5.2.2",
    "@module-federation/enhanced": "0.9.0",
    "date-fns": "4.1.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "7.71.2",
    "react-router-dom": "7.5.0",
    "zod": "4.3.6",
    "zustand": "5.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@rsdoctor/rspack-plugin": "1.5.3",
    "@rspack/cli": "1.3.7",
    "@rspack/core": "1.3.7",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/bun": "latest",
    "@types/react": "19.1.0",
    "@types/react-dom": "19.1.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^3.0.0",
    "jsdom": "^26.0.0",
    "ts-node": "10.9.2",
    "typescript": "5.8.2",
    "vite-tsconfig-paths": "^5.1.0",
    "vitest": "^3.0.0"
  }
}
